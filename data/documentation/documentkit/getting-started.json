{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"DocumentKit is a Swift library that adds more capabilities to "},{"type":"codeVoice","code":"DocumentGroup"},{"type":"text","text":"-based iOS apps."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Document-based SwiftUI apps use a "},{"type":"codeVoice","code":"DocumentGroup"},{"type":"text","text":" scene, into which you can load custom views to edit various document types. It’s an easy and powerful way to create apps that can edit documents and store them on the user’s device and in the cloud."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"However, document apps are currently very limited when it comes to customizations."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, you can’t add custom toolbar items to the document browser, and since a "},{"type":"codeVoice","code":"DocumentGroup"},{"type":"text","text":" (unlike regular SwiftUI apps) doesn’t have a view until you open a document, you can’t present initial onboarding screens or modals from the document browser."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"DocumentKit aims to solve these problems."}]},{"anchor":"How-to-inspect-the-document-group","level":2,"type":"heading","text":"How to inspect the document group"},{"type":"paragraph","inlineContent":[{"type":"text","text":"DocumentKit has a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/DocumentKit\/documentation\/DocumentKit\/DocumentGroupInspector"},{"type":"text","text":" protocol, that lets you inspect the current document group."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All you have to do is to add the protocol to any type, to let it access the underlying document browser:"}]},{"type":"codeListing","syntax":"swift","code":["struct MyView: View, DocumentGroupInspector {","","    var body: some View {","        Text(\"Hello, modal!\")","    }","    ","    var allowsDocumentCreation: Bool {","        documentBrowser?.allowsDocumentCreation ?? false","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also use the protocol to dismiss the currently presented document:"}]},{"type":"codeListing","syntax":"swift","code":["struct MyButton: View, DocumentGroupInspector {","","    var body: some View {","        Button(\"Dismiss\", action: dismissCurrentDocument)","    }","}"]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that the "},{"type":"codeVoice","code":"DocumentGroup"},{"type":"text","text":" must have been presented for this to work. The internal functionality adds a security delay whenever needed, to ensure that the browser is available."}]}],"type":"aside","name":"Important"},{"anchor":"How-to-present-modal-screens","level":2,"type":"heading","text":"How to present modal screens"},{"type":"paragraph","inlineContent":[{"type":"text","text":"DocumentKit has a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/DocumentKit\/documentation\/DocumentKit\/DocumentGroupModal"},{"type":"text","text":" protocol, that lets you present any SwiftUI view as a modal from any "},{"type":"codeVoice","code":"DocumentGroup"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All you have to do is to add the protocol to your view:"}]},{"type":"codeListing","syntax":"swift","code":["struct MyModalView: DocumentGroupModal {","","    var body: some View {","        Text(\"Hello, modal!\")","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can now present the view as a sheet, full screen cover, or using any UIKit presentation style:"}]},{"type":"codeListing","syntax":"swift","code":["MyModalView()","    .presentAsDocumentGroupSheet()","    \/\/ .presentAsDocumentGroupFullScreenCover()","    \/\/ .presentAsDocumentGroupModal(.overCurrentContext)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This means that any SwiftUI view can be easily presented as a modal over any "},{"type":"codeVoice","code":"DocumentGroup"},{"type":"text","text":"."}]},{"anchor":"How-to-present-an-initial-onboarding-screen","level":2,"type":"heading","text":"How to present an initial onboarding screen"},{"type":"paragraph","inlineContent":[{"type":"text","text":"We can now use the "},{"type":"codeVoice","code":"DocumentGroupModal"},{"type":"text","text":" to easily open an app onboarding when a "},{"type":"codeVoice","code":"DocumentGroup"},{"type":"text","text":"-based app starts."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All you have to do is to add an "},{"type":"codeVoice","code":"onboardingSheet"},{"type":"text","text":" or "},{"type":"codeVoice","code":"onboardingFullScreenCover"},{"type":"text","text":" to the "},{"type":"codeVoice","code":"DocumentGroup"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["@main","struct MyApp: App {","","    var body: some Scene {","        DocumentGroup(newDocument: MyDocument()) { file in","            ContentView(document: file.$document)","        }.onboardingSheet {","            MyModalView()","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will present the onboarding screen "},{"type":"emphasis","inlineContent":[{"type":"text","text":"once"}]},{"type":"text","text":", after which it will not be shown again."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to present different onboarding experiences, you can provide a custom "},{"type":"codeVoice","code":"id"},{"type":"text","text":" for each onboarding. You can also provide a custom delay and your own "},{"type":"codeVoice","code":"UserDefaults"},{"type":"text","text":" store."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to programmatically get and set the presentation state of a certain onboarding, you can use the "},{"type":"codeVoice","code":"documentGroupOnboardingState(...)"},{"type":"text","text":", "},{"type":"codeVoice","code":"resetDocumentGroupOnboardingState(...)"},{"type":"text","text":" and "},{"type":"codeVoice","code":"setDocumentGroupOnboardingState(...)"},{"type":"text","text":" "},{"type":"codeVoice","code":"UserDefaults"},{"type":"text","text":" extensions."}]},{"anchor":"How-to-customize-the-document-browser","level":2,"type":"heading","text":"How to customize the document browser"},{"type":"paragraph","inlineContent":[{"type":"text","text":"DocumentKit adds "},{"type":"codeVoice","code":"DocumentGroup"},{"type":"text","text":" extensions to let you modify the underlying document browser."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, you can add additional bar button items, configure some predefined properties and use "},{"type":"codeVoice","code":"tryCustomizeBrowser"},{"type":"text","text":" to perform any customization you want:"}]},{"type":"codeListing","syntax":"swift","code":["@main","struct MyApp: App {","","    var body: some Scene {","        DocumentGroup(newDocument: DemoDocument()) { file in","            ContentView(document: file.$document)","        }","        .onboardingSheet {","            MyModalView()","        }","        .additionalNavigationBarButtonItems(","            leading: [...],","            trailing: [...]","        )","        .allowsDocumentCreation(true)","        .allowsPickingMultipleItems(true)","        .showFileExtensions(true)","        .tryCustomizeBrowser { $0.allowsDocumentCreation = false }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since "},{"type":"codeVoice","code":"tryCustomizeBrowser"},{"type":"text","text":" is not as nice as using the other extensions, more extensions may be added in the future."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/documentkit\/getting-started"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/DocumentKit\/documentation\/DocumentKit\/Getting-Started","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"This article explains how to get started with DocumentKit."}],"kind":"article","metadata":{"roleHeading":"Article","title":"Getting Started","role":"article","modules":[{"name":"DocumentKit"}]},"hierarchy":{"paths":[["doc:\/\/DocumentKit\/documentation\/DocumentKit"]]},"references":{"doc://DocumentKit/documentation/DocumentKit/DocumentGroupInspector":{"role":"symbol","title":"DocumentGroupInspector","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"DocumentGroupInspector"}],"abstract":[{"type":"text","text":"This protocol can be implemented by any type that should be"},{"type":"text","text":" "},{"type":"text","text":"able to inspect the current "},{"type":"codeVoice","code":"DocumentGroup"},{"type":"text","text":"."}],"identifier":"doc:\/\/DocumentKit\/documentation\/DocumentKit\/DocumentGroupInspector","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"DocumentGroupInspector"}],"url":"\/documentation\/documentkit\/documentgroupinspector"},"doc://DocumentKit/documentation/DocumentKit":{"role":"collection","title":"DocumentKit","abstract":[{"type":"text","text":"DocumentKit is a Swift library that adds more capabilities to "},{"type":"codeVoice","code":"DocumentGroup"},{"type":"text","text":"-based iOS apps."}],"identifier":"doc:\/\/DocumentKit\/documentation\/DocumentKit","kind":"symbol","type":"topic","url":"\/documentation\/documentkit"},"doc://DocumentKit/documentation/DocumentKit/DocumentGroupModal":{"role":"symbol","title":"DocumentGroupModal","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"DocumentGroupModal"}],"abstract":[{"type":"text","text":"This protocol can be implemented by any view, that you have"},{"type":"text","text":" "},{"type":"text","text":"to be able to open from a document group."}],"identifier":"doc:\/\/DocumentKit\/documentation\/DocumentKit\/DocumentGroupModal","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"DocumentGroupModal"}],"url":"\/documentation\/documentkit\/documentgroupmodal"}}}